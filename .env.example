# ============================================
# DeepSeek API 配置
# ============================================

# 必填：你的 DeepSeek API 密钥
# 访问 https://platform.deepseek.com/ 注册获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础地址（无需修改）
DEEPSEEK_API_BASE=https://api.deepseek.com

# 模型名称，目前使用 deepseek-chat（对应 DeepSeek-V4）
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 向量数据库持久化路径
# ============================================

# Chroma 向量数据库持久化目录，运行时自动创建
CHROMA_DB_DIR=./chroma_db

# 文档加载目录，将 PDF/TXT 文件放入此路径
DOCS_DIR=./data/docs

# ============================================
# 文本分块参数
# ============================================

# 每个文本块的最大字符数
# 值越小检索粒度越细但上下文越碎片化，值越大上下文越完整但可能包含噪声
# 中文场景推荐 500-800 字符
CHUNK_SIZE=500

# 相邻文本块之间的重叠字符数
# 适当增加重叠可以避免关键信息被分割到两个块之间导致遗漏
# 推荐设置为 chunk_size 的 10%-20%
CHUNK_OVERLAP=100

# ============================================
# 检索参数
# ============================================

# 每次检索返回的最相关文本块数量
# Top-K 越大召回越全但可能引入噪声，越小答案越聚焦
RETRIEVAL_TOP_K=4

# ============================================
# 嵌入模型
# ============================================

# HuggingFace 嵌入模型名称
# 中文推荐：BAAI/bge-small-zh-v1.5（轻量快速）或 BAAI/bge-base-zh-v1.5（更精准）
# 英文推荐：sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5